{
  "name": "@holistic/app",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint:services": "eslint --no-eslintrc -c ../eslint.services.cjs --resolve-plugins-relative-to .. --no-error-on-unmatched-pattern --ext .ts,.tsx ../../services/*/ui ../external/*",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "pnpm run lint:services && pnpm run typecheck && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@holistic/ui": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "vite": "^5.4.9"
  }
}
