#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SERVICES_DIR="$REPO_ROOT/services"
MANIFEST="$SERVICES_DIR/manifest"
DASHBOARD_DIR="$SERVICES_DIR/dashboard"
INVITES_TOOL="$DASHBOARD_DIR/lib/holistic-invites.py"
PERMS_TOOL="$DASHBOARD_DIR/lib/holistic-perms.py"
PERMS_DIR="/etc/holistic/permissions.d"

# Shared provisioning logic (single source of truth, also used by the sudo wrappers).
source "$DASHBOARD_DIR/lib/holistic-user.sh"

usage() {
    cat <<'EOF'
holistic — Holistic Homeserver orchestrator

Usage:
  holistic setup                    System prep + install all services
  holistic setup <service>          Install/repair a single service (no system prep)
  holistic start|stop|restart [target]   Control services (target: dashboard|caddy|samba|all; default all)
  holistic user add <name> [label]  Create a NEW user (Linux + Samba, both passwords)
  holistic user adopt <name>        Onboard an EXISTING Linux user (groups + drive + one unified password)
  holistic user unadopt <name>      Remove an adopted user from holistic (keeps Linux account, home + drive)
  holistic user passwd <name>       Change a user's password (Linux + Samba)
  holistic user delete <name> [--purge]   Remove a user (--purge deletes their files)
  holistic invite new [--note X] [--expires-days N]   Mint a registration invite code
  holistic invite list              List invite codes and their state
  holistic invite revoke <id>       Revoke an invite
  holistic update                   Pull latest repo + re-run setup
  holistic list                     List services in install order
  holistic status                   Show whether each service is running
  holistic perms list|validate      List/validate service rights manifests (permissions.d)
  holistic help                     Show this help
EOF
}

# --- helpers ---

read_manifest() {
    if [[ ! -f "$MANIFEST" ]]; then
        echo "[holistic] ERROR: manifest not found: $MANIFEST" >&2
        exit 1
    fi
    grep -vE '^[[:space:]]*(#|$)' "$MANIFEST" | tr -d '[:blank:]'
}

require_root() {
    if [[ $EUID -ne 0 ]]; then
        echo "[holistic] ERROR: this command must run as root (use sudo)" >&2
        exit 1
    fi
}

# Read a password twice from the terminal into $REPLY_PW (no echo).
read_password_twice() {
    local prompt="$1" pw pw2
    read -r -s -p "$prompt" pw; echo
    read -r -s -p "Repeat: " pw2; echo
    [[ -n "$pw" ]] || { echo "[holistic] ERROR: empty password" >&2; return 1; }
    [[ "$pw" == "$pw2" ]] || { echo "[holistic] ERROR: passwords do not match" >&2; return 1; }
    REPLY_PW="$pw"
}

# --- system prep ---

system_prep() {
    echo "[holistic] === system prep ==="

    # Base packages
    apt-get update -qq
    apt-get install -y -qq curl git python3 > /dev/null

    # Groups (admin = the OS sudo group, not an app-managed group)
    getent group family         >/dev/null || groupadd family
    getent group smbusers       >/dev/null || groupadd smbusers

    # Unprivileged backend system user + its state dirs
    getent passwd holistic >/dev/null || \
        useradd --system --shell /usr/sbin/nologin --home-dir /var/lib/holistic holistic
    install -d -o holistic -g holistic -m 0755 /etc/holistic
    install -d -o holistic -g holistic -m 0755 /etc/holistic/permissions.d  # service rights manifests (drop-in)
    install -d -o holistic -g holistic -m 2750 /var/lib/holistic   # setgid: invites/secrets stay group-readable
    install -d -o holistic -g holistic -m 0700 /var/lib/holistic/profiles  # app-managed profile data + avatars

    # Storage layout
    mkdir -p /srv/storage/users
    mkdir -p /srv/storage/family
    chown root:family /srv/storage/family
    chmod 2770 /srv/storage/family

    install_privileged_surface

    echo "[holistic] system prep done"
}

# Install the single-source-of-truth lib + sudo-gated wrappers + sudoers + PAM service.
# These let `holistic user add` and the dashboard backend share identical provisioning.
install_privileged_surface() {
    [[ -d "$DASHBOARD_DIR" ]] || return 0
    echo "[holistic] installing privileged surface (lib, wrappers, sudoers, pam)"

    install -D -m 0755 "$DASHBOARD_DIR/lib/holistic-user.sh"   /usr/local/lib/holistic/holistic-user.sh
    install -D -m 0755 "$DASHBOARD_DIR/lib/holistic-invites.py" /usr/local/lib/holistic/holistic-invites.py
    install -D -m 0755 "$DASHBOARD_DIR/lib/holistic-perms.py"  /usr/local/lib/holistic/holistic-perms.py

    local w
    for w in holistic-user-add holistic-user-passwd holistic-user-delete \
             holistic-user-exists holistic-invite-consume holistic-pam-check; do
        install -m 0755 -o root -g root "$DASHBOARD_DIR/sbin/$w" "/usr/local/sbin/$w"
    done

    install -m 0644 "$DASHBOARD_DIR/pam.d/holistic-dashboard" /etc/pam.d/holistic-dashboard

    # Sudoers: validate before trusting it.
    install -m 0440 -o root -g root "$DASHBOARD_DIR/sudoers.d/holistic" /etc/sudoers.d/holistic
    if ! visudo -cf /etc/sudoers.d/holistic >/dev/null; then
        rm -f /etc/sudoers.d/holistic
        echo "[holistic] ERROR: sudoers validation failed; removed" >&2
        exit 1
    fi

    assert_safe_perms /usr/local/lib/holistic/holistic-user.sh \
                      /usr/local/lib/holistic/holistic-invites.py \
                      /usr/local/sbin/holistic-user-add \
                      /usr/local/sbin/holistic-user-passwd \
                      /usr/local/sbin/holistic-user-delete \
                      /usr/local/sbin/holistic-user-exists \
                      /usr/local/sbin/holistic-invite-consume \
                      /usr/local/sbin/holistic-pam-check
}

# A NOPASSWD-to-root wrapper that is group/other-writable is a root escalation. Refuse.
assert_safe_perms() {
    local f owner mode
    for f in "$@"; do
        [[ -e "$f" ]] || continue
        owner="$(stat -c '%U' "$f")"
        mode="$(stat -c '%a' "$f")"
        if [[ "$owner" != "root" ]]; then
            echo "[holistic] ERROR: $f not owned by root (owner=$owner)" >&2; exit 1
        fi
        if [[ "${mode: -1}" =~ [2367] || "${mode: -2:1}" =~ [2367] ]]; then
            echo "[holistic] ERROR: $f is group/other-writable (mode=$mode)" >&2; exit 1
        fi
    done
}

# --- commands ---

run_service() {
    local svc="$1"
    local script="$SERVICES_DIR/$svc/install.sh"
    if [[ ! -f "$script" ]]; then
        echo "[holistic] ERROR: no install.sh for service '$svc'" >&2
        return 1
    fi
    echo "[holistic] === installing service: $svc ==="
    bash "$script"
}

cmd_setup() {
    require_root
    if [[ $# -ge 1 ]]; then
        run_service "$1"
        return
    fi
    system_prep
    local svc
    while read -r svc; do
        run_service "$svc"
    done < <(read_manifest)

    # Reconcile the rights groups every service declared, backfill default-on rights for
    # existing users (so behaviour is unchanged), then sanity-check the manifests.
    if [[ -f "$PERMS_TOOL" ]]; then
        python3 "$PERMS_TOOL" ensure-groups "$PERMS_DIR" || true
        python3 "$PERMS_TOOL" grant-defaults "$PERMS_DIR" || true
        python3 "$PERMS_TOOL" validate "$PERMS_DIR" || \
            echo "[holistic] WARN: permission manifests have issues (see above)" >&2
    fi
    echo "[holistic] setup complete"
}

cmd_perms() {
    local sub="${1:-list}"; shift || true
    case "$sub" in
        list)          python3 "$PERMS_TOOL" list "$PERMS_DIR" ;;
        validate)      python3 "$PERMS_TOOL" validate "$PERMS_DIR" ;;
        groups)        python3 "$PERMS_TOOL" groups "$PERMS_DIR" ;;
        ensure-groups) require_root; python3 "$PERMS_TOOL" ensure-groups "$PERMS_DIR" ;;
        *) echo "Usage: holistic perms {list|validate|groups|ensure-groups}" >&2; exit 1 ;;
    esac
}

cmd_user_add() {
    require_root
    local name="${1:-}"
    [[ -z "$name" ]] && { echo "Usage: holistic user add <name> [display-name]" >&2; exit 1; }
    shift
    local gecos="${*:-}"

    [[ "$name" =~ ^[a-z][a-z0-9_-]{0,31}$ ]] || { echo "[holistic] ERROR: invalid username" >&2; exit 1; }
    holistic_user_exists "$name" && { echo "[holistic] ERROR: user '$name' already exists" >&2; exit 1; }

    local REPLY_PW
    read_password_twice "Password for $name: " || exit 1

    holistic_user_create_account "$name" "$gecos"
    holistic_set_password "$name" "$REPLY_PW"

    echo "[holistic] user '$name' created (groups: family, smbusers)"
}

cmd_user_adopt() {
    require_root
    local name="${1:-}"
    [[ -z "$name" ]] && { echo "Usage: holistic user adopt <name>" >&2; exit 1; }
    [[ "$name" =~ ^[a-z][a-z0-9_-]{0,31}$ ]] || { echo "[holistic] ERROR: invalid username" >&2; exit 1; }
    holistic_user_exists "$name" || { echo "[holistic] ERROR: no Linux user '$name' — adopt onboards an EXISTING OS user; use 'user add' to create a new one" >&2; exit 1; }
    [[ "$(id -u "$name")" -ge 1000 ]] || { echo "[holistic] ERROR: refusing to adopt system user '$name' (uid < 1000)" >&2; exit 1; }

    holistic_user_adopt "$name"
    # One account, one password: set Linux + Samba together so the identity never diverges.
    local REPLY_PW
    read_password_twice "Set one password for '$name' (Linux login + dashboard + Samba): " || exit 1
    holistic_set_password "$name" "$REPLY_PW"

    echo "[holistic] adopted '$name' (groups: $HOLISTIC_GROUPS; drive: $HOLISTIC_USERS_ROOT/$name; one unified password set)"
}

cmd_user_unadopt() {
    require_root
    local name="${1:-}"
    [[ -z "$name" ]] && { echo "Usage: holistic user unadopt <name>" >&2; exit 1; }
    holistic_user_exists "$name" || { echo "[holistic] ERROR: no such user '$name'" >&2; exit 1; }
    holistic_user_unadopt "$name"
    echo "[holistic] unadopted '$name' (removed from $HOLISTIC_GROUPS + Samba; Linux account, home and drive kept)"
}

cmd_user_passwd() {
    require_root
    local name="${1:-}"
    [[ -z "$name" ]] && { echo "Usage: holistic user passwd <name>" >&2; exit 1; }
    holistic_user_exists "$name" || { echo "[holistic] ERROR: no such user '$name'" >&2; exit 1; }

    local REPLY_PW
    read_password_twice "New password for $name: " || exit 1
    holistic_set_password "$name" "$REPLY_PW"

    echo "[holistic] password updated for '$name' (Linux + Samba)"
}

cmd_user_delete() {
    require_root
    local name="${1:-}" purge="${2:-}"
    [[ -z "$name" ]] && { echo "Usage: holistic user delete <name> [--purge]" >&2; exit 1; }
    holistic_user_exists "$name" || { echo "[holistic] ERROR: no such user '$name'" >&2; exit 1; }
    holistic_user_delete "$name" "$purge"
    echo "[holistic] user '$name' deleted"
}

cmd_invite() {
    require_root
    local sub="${1:-}"; shift || true
    case "$sub" in
        new)    python3 "$INVITES_TOOL" new "$@" ;;
        list)   python3 "$INVITES_TOOL" list ;;
        revoke) python3 "$INVITES_TOOL" revoke "$@" ;;
        *)      echo "Usage: holistic invite {new [--note X] [--expires-days N] | list | revoke <id>}" >&2; exit 1 ;;
    esac
}

cmd_update() {
    echo "[holistic] pulling latest..."
    git -C "$REPO_ROOT" pull --ff-only

    echo "[holistic] re-running setup..."
    cmd_setup
}

cmd_list() {
    read_manifest
}

# --- service lifecycle (systemd) ---

# The systemd units holistic manages. (cloudflared belongs to sxgate, not holistic.)
HOLISTIC_UNITS="holistic-dashboard caddy smbd nmbd"

# Map a friendly target to its unit(s); no target / "all" => the whole stack.
holistic_units_for() {
    case "${1:-all}" in
        all)             echo "$HOLISTIC_UNITS" ;;
        dashboard|web)   echo "holistic-dashboard" ;;
        caddy|proxy)     echo "caddy" ;;
        samba|smb)       echo "smbd nmbd" ;;
        holistic-dashboard|caddy|smbd|nmbd) echo "$1" ;;
        *) echo "[holistic] ERROR: unknown target '$1' (use: dashboard|caddy|samba|all)" >&2; return 1 ;;
    esac
}

cmd_lifecycle() {
    require_root
    local action="$1" target="${2:-all}" units u rc=0
    units="$(holistic_units_for "$target")" || exit 1
    for u in $units; do
        if systemctl "$action" "$u"; then
            echo "[holistic] $action: $u"
        else
            echo "[holistic] WARN: '$action $u' failed — installed? run 'sudo ./holistic setup'" >&2
            rc=1
        fi
    done
    return "$rc"
}

cmd_status() {
    local u state
    for u in $HOLISTIC_UNITS; do
        state="$(systemctl is-active "$u" 2>/dev/null || true)"
        printf '  %-20s %s\n' "$u" "${state:-unknown}"
    done
    if systemctl cat cloudflared >/dev/null 2>&1; then
        state="$(systemctl is-active cloudflared 2>/dev/null || true)"
        printf '  %-20s %s\n' "cloudflared" "${state:-unknown} (sxgate tunnel)"
    fi
}

# --- main ---

main() {
    local cmd="${1:-help}"
    case "$cmd" in
        setup)          shift; cmd_setup "$@" ;;
        start)          shift; cmd_lifecycle start "$@" ;;
        stop)           shift; cmd_lifecycle stop "$@" ;;
        restart)        shift; cmd_lifecycle restart "$@" ;;
        user)
            shift
            case "${1:-}" in
                add)     shift; cmd_user_add "$@" ;;
                adopt)   shift; cmd_user_adopt "$@" ;;
                unadopt) shift; cmd_user_unadopt "$@" ;;
                passwd)  shift; cmd_user_passwd "$@" ;;
                delete)  shift; cmd_user_delete "$@" ;;
                *)       echo "Usage: holistic user {add|adopt|unadopt|passwd|delete} <name>" >&2; exit 1 ;;
            esac
            ;;
        invite)         shift; cmd_invite "$@" ;;
        perms)          shift; cmd_perms "$@" ;;
        update)         cmd_update ;;
        list)           cmd_list ;;
        status)         cmd_status ;;
        help|-h|--help) usage ;;
        *)
            echo "[holistic] unknown command: $cmd" >&2
            usage
            exit 1
            ;;
    esac
}

main "$@"
