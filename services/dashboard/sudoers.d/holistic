# Installed to /etc/sudoers.d/holistic (root:root 0440); validated with `visudo -cf`.
# The unprivileged `holistic` backend user may run ONLY these wrappers, nothing else.

# User provisioning + invite consumption — run as root.
holistic ALL=(root) NOPASSWD: /usr/local/sbin/holistic-user-add, /usr/local/sbin/holistic-user-passwd, /usr/local/sbin/holistic-user-delete, /usr/local/sbin/holistic-user-exists, /usr/local/sbin/holistic-invite-consume

# File broker — run AS the target family account only (the %smbusers ceiling, never root/system).
holistic ALL=(%smbusers) NOPASSWD: /usr/local/sbin/holistic-fs
