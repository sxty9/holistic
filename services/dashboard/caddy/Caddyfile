# Holistic dashboard — static SPA + /api proxy, local TLS.
# Access at https://holistic.local (add it to /etc/hosts or your router DNS).
# `tls internal` uses Caddy's local CA; trust it once on each client, or swap in
# mkcert-generated certs with:  tls /etc/holistic/cert.pem /etc/holistic/key.pem
holistic.local {
	handle /api/* {
		reverse_proxy 127.0.0.1:8770
	}
	handle {
		root * /opt/holistic/www
		try_files {path} /index.html
		file_server
	}
	tls internal
}
